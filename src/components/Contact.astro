---
const services = [
  { value: '', label: 'Selecciona un servicio' },
  { value: 'software', label: 'Desarrollo de Software a Medida' },
  { value: 'cloud', label: 'Arquitectura Cloud' },
  { value: 'ecommerce', label: 'E-commerce' },
  { value: 'mobile', label: 'Aplicaciones Móviles' },
  { value: 'ia', label: 'Herramientas IA' },
  { value: 'wordpress', label: 'Plugins WordPress' },
  { value: 'seo', label: 'SEO y Optimización' }
];
---

<section class="contact" id="contacto" data-scroll-3d>
  <div class="contact-container">
    <div class="section-header reveal">
      <span class="section-tag">
        <span class="tag-pulse"></span>
        Contacto
      </span>
      <h2 class="section-title">
        ¿Listo para <span class="text-gradient">comenzar</span>?
      </h2>
      <p class="section-description">
        Cuéntanos sobre tu proyecto y te ayudaremos a convertir tu idea en realidad
      </p>
    </div>

    <div class="contact-grid">
      <form class="contact-form glass reveal reveal-delay-1" id="contactForm">
        <div class="form-group">
          <label for="name">Nombre completo</label>
          <input type="text" id="name" name="name" required placeholder="Tu nombre" autocomplete="name" />
          <div class="input-line"></div>
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="tu@email.com" autocomplete="email" />
          <div class="input-line"></div>
        </div>

        <div class="form-group">
          <label for="service">Servicio de interés</label>
          <div class="select-shell">
            <select id="service" name="service">
              {services.map((service) => (
                <option value={service.value}>{service.label}</option>
              ))}
            </select>
            <svg class="select-icon" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5 7.5L10 12.5L15 7.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        </div>

        <div class="form-group">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" rows="4" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
          <div class="input-line"></div>
        </div>

        <button type="submit" class="submit-btn" id="contactSubmitBtn">
          <span class="submit-label">Enviar Mensaje</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>

      <div class="contact-modal" id="contactSuccessModal" aria-hidden="true">
        <div class="contact-modal-backdrop" data-close-modal></div>
        <div class="contact-modal-card glass" role="dialog" aria-modal="true" aria-labelledby="contactModalTitle">
          <div class="modal-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <path d="M5 13L9 17L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 id="contactModalTitle">Mensaje enviado</h3>
          <p>
            Recibimos tu solicitud correctamente. Te responderemos pronto desde Skylink.
          </p>
          <button type="button" class="modal-close-btn" id="contactModalCloseBtn">Cerrar</button>
        </div>
      </div>

      <div class="contact-info reveal reveal-delay-2">
        <div class="info-card glass">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8L10.89 13.26C11.2187 13.4793 11.6049 13.5963 12 13.5963C12.3951 13.5963 12.7813 13.4793 13.11 13.26L21 8M5 19H19C19.5304 19 20.0391 18.7893 20.4142 18.4142C20.7893 18.0391 21 17.5304 21 17V7C21 6.46957 20.7893 5.96086 20.4142 5.58579C20.0391 5.21071 19.5304 5 19 5H5C4.46957 5 3.96086 5.21071 3.58579 5.58579C3.21071 5.96086 3 6.46957 3 7V17C3 17.5304 3.21071 18.0391 3.58579 18.4142C3.96086 18.7893 4.46957 19 5 19Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h4>Email</h4>
            <a href="mailto:contacto@valinkgroup.com" class="info-link primary-link">contacto@valinkgroup.com</a>
            <span class="info-badge">Respuesta en 24 horas</span>
          </div>
        </div>

        <div class="info-card glass">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92V19.92C22 20.48 21.56 20.93 21 20.97C20.77 20.99 20.48 21 20 21C10.61 21 3 13.39 3 4C3 3.52 3.01 3.23 3.03 3C3.07 2.44 3.52 2 4.08 2H7.08C7.56 2 7.98 2.34 8.07 2.81L8.82 6.81C8.9 7.23 8.74 7.66 8.41 7.93L6.41 9.53C7.7 12.15 9.85 14.3 12.47 15.59L14.07 13.59C14.34 13.26 14.77 13.1 15.19 13.18L19.19 13.93C19.66 14.02 20 14.44 20 14.92V16.92Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h4>Teléfono</h4>
            <a href="tel:+584125958838" class="info-link primary-link">+58 412-5958838</a>
            <span class="info-badge">Lun - Vie, 9:00 - 18:00</span>
          </div>
        </div>

        <div class="info-card glass highlight-card">
          <div class="highlight-glow"></div>
          <div class="info-icon accent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 10V3L4 14H11V21L20 10H13Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <h4>¿Proyecto urgente?</h4>
            <p>Contáctanos directamente para una consulta inmediata</p>
            <a href="tel:+584125958838" class="info-link">Llamar Ahora →</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.getElementById('contactForm');
  const submitButton = document.getElementById('contactSubmitBtn');
  const submitLabel = submitButton?.querySelector('.submit-label');
  const successModal = document.getElementById('contactSuccessModal');
  const closeModalButton = document.getElementById('contactModalCloseBtn');

  const setModalState = (isOpen) => {
    if (!successModal) return;
    successModal.classList.toggle('is-open', isOpen);
    successModal.setAttribute('aria-hidden', String(!isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };

  closeModalButton?.addEventListener('click', () => setModalState(false));
  successModal?.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof HTMLElement && target.hasAttribute('data-close-modal')) {
      setModalState(false);
    }
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setModalState(false);
    }
  });

  contactForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!(contactForm instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement)) {
      return;
    }

    const formData = new FormData(contactForm);
    const payload = Object.fromEntries(formData.entries());

    submitButton.disabled = true;
    submitButton.classList.add('is-loading');
    if (submitLabel) {
      submitLabel.textContent = 'Enviando...';
    }

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        throw new Error('No se pudo enviar el formulario');
      }

      contactForm.reset();
      setModalState(true);
    } catch (error) {
      window.alert('No pudimos enviar tu mensaje en este momento. Intenta de nuevo en unos minutos.');
    } finally {
      submitButton.disabled = false;
      submitButton.classList.remove('is-loading');
      if (submitLabel) {
        submitLabel.textContent = 'Enviar Mensaje';
      }
    }
  });
</script>

<style>
  .contact {
    padding: 8rem 3rem;
    position: relative;
    transform-style: preserve-3d;
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    background: rgba(96, 176, 224, 0.1);
    border: 1px solid rgba(96, 176, 224, 0.2);
    color: var(--accent-light);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .tag-pulse {
    width: 6px;
    height: 6px;
    background: #60c0f0;
    border-radius: 50%;
    animation: tagPulse 2s infinite;
    box-shadow: 0 0 8px rgba(96, 192, 240, 0.6);
  }

  @keyframes tagPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .section-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form */
  .contact-form {
    padding: 2.5rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    transition: all 0.5s var(--ease-out-expo);
  }

  .contact-form:hover {
    border-color: rgba(96, 176, 224, 0.15);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 0 0 60px rgba(96, 176, 224, 0.03);
  }

  .form-group {
    margin-bottom: 1.5rem;
    position: relative;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.85rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.3s;
    cursor: none;
  }

  .select-shell {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
  }

  .select-shell:focus-within {
    border-color: rgba(96, 176, 224, 0.35);
    background: rgba(96, 176, 224, 0.05);
    box-shadow: 0 0 0 4px rgba(96, 176, 224, 0.08);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
  }

  .form-group select {
    appearance: none;
    -webkit-appearance: none;
    padding: 1rem 2rem 1rem 0;
    border: none;
    background: transparent;
    cursor: none;
  }

  .select-icon {
    width: 18px;
    height: 18px;
    color: var(--accent-light);
    pointer-events: none;
    flex-shrink: 0;
  }

  .form-group select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .input-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient-1);
    transition: width 0.4s var(--ease-out-expo);
  }

  .form-group input:focus ~ .input-line,
  .form-group select:focus ~ .input-line,
  .form-group textarea:focus ~ .input-line {
    width: 100%;
  }

  .select-shell + .input-line {
    display: none;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    background-image: none;
    border: 1px solid rgba(96, 176, 224, 0.28);
    border-radius: 100px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.4s var(--ease-out-expo);
    margin-top: 0.5rem;
    width: 100%;
    justify-content: center;
    box-shadow: none;
    cursor: none;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(96, 176, 224, 0.55);
    background: rgba(96, 176, 224, 0.08);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    pointer-events: none;
  }

  .submit-btn.is-loading {
    background: rgba(96, 176, 224, 0.12);
    border-color: rgba(96, 176, 224, 0.4);
  }

  .contact-modal {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 1200;
  }

  .contact-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .contact-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .contact-modal-card {
    position: relative;
    z-index: 1;
    width: min(92vw, 420px);
    padding: 2rem;
    border-radius: 24px;
    text-align: center;
    border: 1px solid rgba(96, 176, 224, 0.18);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.35);
  }

  .modal-icon {
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    margin: 0 auto 1rem;
    border-radius: 50%;
    color: var(--accent-light);
    background: rgba(96, 176, 224, 0.12);
    border: 1px solid rgba(96, 176, 224, 0.22);
  }

  .modal-icon svg {
    width: 28px;
    height: 28px;
  }

  .contact-modal-card h3 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
  }

  .contact-modal-card p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .modal-close-btn {
    width: 100%;
    border: 1px solid rgba(96, 176, 224, 0.28);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-primary);
    border-radius: 999px;
    padding: 0.95rem 1.25rem;
    font: inherit;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: none;
  }

  .modal-close-btn:hover {
    background: rgba(96, 176, 224, 0.08);
    border-color: rgba(96, 176, 224, 0.45);
  }

  /* Contact info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 16px;
    transition: all 0.4s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }

  .info-card:hover {
    border-color: rgba(96, 176, 224, 0.2);
    transform: translateX(4px) translateY(-2px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
  }

  .info-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
  }

  .info-icon svg {
    width: 22px;
    height: 22px;
  }

  .info-icon.accent {
    background: rgba(96, 176, 224, 0.15);
    color: var(--accent-light);
  }

  .info-card h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .info-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .info-badge {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--accent-light);
    opacity: 0.7;
  }

  .highlight-card {
    border-color: rgba(96, 176, 224, 0.2) !important;
  }

  .highlight-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(96, 176, 224, 0.08), transparent 60%);
    pointer-events: none;
  }

  .info-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--accent-light);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
  }

  .info-link:hover {
    color: white;
  }

  .primary-link {
    margin-top: 0;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .primary-link:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .contact { padding: 5rem 1.5rem; }
    .contact-grid { grid-template-columns: 1fr; }
    .contact-form { padding: 2rem 1.5rem; }
    body .form-group input,
    body .form-group select,
    body .form-group textarea {
      cursor: auto;
    }
    body .submit-btn,
    body .modal-close-btn {
      cursor: pointer;
    }
  }
</style>
