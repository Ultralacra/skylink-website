---
const steps = [
  {
    number: '01',
    title: 'Consulta Inicial',
    description: 'Analizamos tus necesidades y objetivos para entender exactamente lo que tu negocio requiere.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><path d="M20 8C13.4 8 8 13.4 8 20C8 26.6 13.4 32 20 32C26.6 32 32 26.6 32 20C32 13.4 26.6 8 20 8Z" stroke="currentColor" stroke-width="1.5"/><path d="M20 14V20L24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`
  },
  {
    number: '02',
    title: 'Estrategia y Diseño',
    description: 'Creamos un plan detallado y diseñamos la arquitectura perfecta para tu solución.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><rect x="8" y="8" width="24" height="24" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M14 20H26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 15H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 25H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`
  },
  {
    number: '03',
    title: 'Desarrollo',
    description: 'Nuestro equipo desarrolla tu proyecto usando las mejores prácticas y tecnologías modernas.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><path d="M15 14L9 20L15 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M25 14L31 20L25 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 10L18 30" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`
  },
  {
    number: '04',
    title: 'Lanzamiento y Soporte',
    description: 'Desplegamos tu proyecto y proporcionamos soporte continuo para garantizar su éxito.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><path d="M20 8L24 16L32 18L26 24L28 32L20 28L12 32L14 24L8 18L16 16L20 8Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`
  }
];
---

<section class="process" id="proceso" data-scroll-3d>
  <div class="process-container">
    <div class="section-header reveal">
      <span class="section-tag">
        <span class="tag-pulse"></span>
        Nuestro Proceso
      </span>
      <h2 class="section-title">
        Un enfoque estructurado para<br /><span class="text-gradient">resultados excepcionales</span>
      </h2>
      <p class="section-description">
        Metodología probada que garantiza calidad, transparencia y entrega a tiempo en cada proyecto
      </p>
    </div>

    <div class="process-timeline">
      <div class="timeline-line">
        <div class="timeline-progress" id="timelineProgress"></div>
        <div class="timeline-glow" id="timelineGlow"></div>
      </div>

      {steps.map((step, i) => (
        <div class={`process-step reveal reveal-delay-${i + 1}`}>
          <div class="step-marker">
            <span class="step-number">{step.number}</span>
            <div class="step-pulse"></div>
            <div class="step-ring"></div>
          </div>
          <div class="step-content glass">
            <div class="step-content-glow"></div>
            <div class="step-icon" set:html={step.icon} />
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Timeline progress on scroll
  const timeline = document.getElementById('timelineProgress');
  const timelineGlow = document.getElementById('timelineGlow');
  const processSection = document.querySelector('.process') as HTMLElement;

  if (timeline && processSection) {
    window.addEventListener('scroll', () => {
      const rect = processSection.getBoundingClientRect();
      const sectionHeight = processSection.offsetHeight;
      const viewportHeight = window.innerHeight;
      
      const progress = Math.min(Math.max(
        (viewportHeight - rect.top) / (sectionHeight + viewportHeight) * 100, 0
      ), 100);
      
      timeline.style.width = progress + '%';
      if (timelineGlow) timelineGlow.style.width = progress + '%';
    });
  }

  // 3D tilt on process cards
  document.querySelectorAll('.step-content').forEach(card => {
    card.addEventListener('mousemove', (e: Event) => {
      const me = e as MouseEvent;
      const rect = (card as HTMLElement).getBoundingClientRect();
      const x = (me.clientX - rect.left) / rect.width;
      const y = (me.clientY - rect.top) / rect.height;
      const tiltX = (y - 0.5) * 8;
      const tiltY = (x - 0.5) * -8;
      (card as HTMLElement).style.transform = `perspective(600px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateY(-8px)`;
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = '';
    });
  });
</script>

<style>
  .process {
    padding: 8rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .process::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 50%, rgba(96, 176, 224, 0.05), transparent);
    pointer-events: none;
  }

  .process-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-tag {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    background: rgba(96, 176, 224, 0.1);
    border: 1px solid rgba(96, 176, 224, 0.2);
    color: var(--accent-light);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .section-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .process-timeline {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .timeline-line {
    position: absolute;
    top: 24px;
    left: 12.5%;
    right: 12.5%;
    height: 2px;
    background: rgba(255, 255, 255, 0.06);
    z-index: 0;
  }

  .timeline-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--gradient-1);
    transition: width 0.1s linear;
  }

  .timeline-glow {
    position: absolute;
    top: -4px;
    left: 0;
    width: 0;
    height: 10px;
    background: var(--gradient-1);
    filter: blur(8px);
    opacity: 0.6;
    transition: width 0.1s linear;
  }

  .process-step {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .step-marker {
    position: relative;
    width: 48px;
    height: 48px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    border: 2px solid rgba(96, 176, 224, 0.3);
    border-radius: 50%;
    z-index: 1;
    transition: all 0.4s var(--ease-out-expo);
  }

  .process-step:hover .step-marker {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(96, 176, 224, 0.3);
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-light);
  }

  .step-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    opacity: 0;
    animation: stepPulse 3s infinite;
  }

  .process-step:nth-child(2) .step-pulse { animation-delay: 0.5s; }
  .process-step:nth-child(3) .step-pulse { animation-delay: 1s; }
  .process-step:nth-child(4) .step-pulse { animation-delay: 1.5s; }

  @keyframes stepPulse {
    0% { opacity: 0.6; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.8); }
  }

  .step-content {
    padding: 2rem 1.5rem;
    border-radius: 16px;
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
  }

  .step-content-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(96, 176, 224, 0.1), transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .process-step:hover .step-content {
    border-color: rgba(96, 176, 224, 0.2);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-8px) perspective(800px) rotateX(2deg);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 0 0 50px rgba(96, 176, 224, 0.05);
  }

  .process-step:hover .step-content-glow {
    opacity: 1;
  }

  .step-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(96, 176, 224, 0.1);
    opacity: 0;
    transition: all 0.5s var(--ease-out-expo);
  }

  .process-step:hover .step-ring {
    opacity: 1;
    inset: -12px;
  }

  .step-icon {
    width: 40px;
    height: 40px;
    color: var(--accent-light);
    margin: 0 auto 1rem;
    opacity: 0.8;
  }

  .step-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .step-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .process-timeline { grid-template-columns: repeat(2, 1fr); }
    .timeline-line { display: none; }
  }

  @media (max-width: 600px) {
    .process { padding: 5rem 1.5rem; }
    .process-timeline { grid-template-columns: 1fr; }
  }
</style>
