<style>
  .features {
    padding: 4rem 3rem 8rem;
    position: relative;
    transform-style: preserve-3d;
  }

  .features-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Marquee */
  .features-marquee {
    overflow: hidden;
    padding: 2rem 0 3rem;
    margin-bottom: 4rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .section-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    background: rgba(96, 176, 224, 0.1);
    border: 1px solid rgba(96, 176, 224, 0.2);
    color: var(--accent-light);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .tag-pulse {
    width: 6px;
    height: 6px;
    background: #60c0f0;
    border-radius: 50%;
    animation: tagPulse 2s infinite;
    box-shadow: 0 0 8px rgba(96, 192, 240, 0.6);
  }

  @keyframes tagPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .marquee-wrapper {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem 0;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    gap: 3rem;
    align-items: center;
    animation: marquee 40s linear infinite;
    white-space: nowrap;
    width: max-content;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .tech-logo {
    width: 44px;
    height: 44px;
    opacity: 0.6;
    transition: opacity 0.3s, transform 0.3s, filter 0.3s;
    object-fit: contain;
  }

  .tech-item:hover .tech-logo {
    opacity: 1;
    transform: scale(1.15);
    filter: drop-shadow(0 0 12px rgba(96, 176, 224, 0.4));
  }

  .tech-item span {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: -0.02em;
    transition: color 0.3s;
  }

  .tech-item:hover span {
    color: var(--text-secondary);
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Features grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .feature-card {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
  }

  .feature-card-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(96, 176, 224, 0.06), transparent 70%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .feature-card:hover .feature-card-bg { opacity: 1; }

  .feature-card:hover {
    border-color: rgba(96, 176, 224, 0.15);
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(-8px) perspective(800px) rotateX(2deg);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 0 0 60px rgba(96, 176, 224, 0.05);
  }

  .feature-icon-wrap {
    position: relative;
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    color: var(--accent-light);
    position: relative;
    z-index: 1;
  }

  .feature-glow {
    position: absolute;
    inset: -10px;
    background: radial-gradient(circle, rgba(96, 176, 224, 0.2), transparent 70%);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.5s;
  }

  .feature-ring {
    position: absolute;
    inset: -5px;
    border: 1px solid rgba(96, 176, 224, 0.15);
    border-radius: 50%;
    opacity: 0;
    transition: all 0.5s var(--ease-out-expo);
  }

  .feature-card:hover .feature-glow {
    opacity: 1;
  }

  .feature-card:hover .feature-ring {
    opacity: 1;
    inset: -10px;
    animation: featureRingSpin 8s linear infinite;
  }

  @keyframes featureRingSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .feature-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .feature-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* CTA Banner */
  .cta-banner {
    position: relative;
    padding: 4rem;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .cta-orb-1 {
    width: 300px;
    height: 300px;
    background: rgba(96, 176, 224, 0.2);
    top: -50%;
    right: -5%;
  }

  .cta-orb-2 {
    width: 200px;
    height: 200px;
    background: rgba(96, 176, 224, 0.15);
    bottom: -30%;
    left: 10%;
  }

  .cta-particles {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(96, 176, 224, 0.15) 1px, transparent 1px);
    background-size: 30px 30px;
    animation: particleDrift 20s linear infinite;
    opacity: 0.5;
  }

  @keyframes particleDrift {
    from { background-position: 0 0; }
    to { background-position: 30px 30px; }
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .cta-text {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cta-banner .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(96, 176, 224, 0.22);
    border-radius: 100px;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.4s var(--ease-out-expo);
    position: relative;
    z-index: 1;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: none;
  }

  .cta-banner .btn-primary svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .cta-banner .btn-primary:hover {
    transform: translateY(-2px);
    background: rgba(96, 176, 224, 0.1);
    border-color: rgba(96, 176, 224, 0.45);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 768px) {
    .features { padding: 3rem 1.5rem 5rem; }
    .features-grid { grid-template-columns: 1fr; }
    .cta-banner {
      flex-direction: column;
      text-align: center;
      padding: 3rem 2rem;
    }
  }
</style>
