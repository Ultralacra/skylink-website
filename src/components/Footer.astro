---
---

<footer class="footer">
  <div class="footer-container">
    <!-- Top: Logo centered + nav + social -->
    <div class="footer-top">
      <a href="#" class="footer-logo">
        <img src="/logos/S Blanco.png" alt="Skylink" width="24" height="24" style="object-fit:contain" />
        <span>Skylink</span>
      </a>

      <nav class="footer-nav">
        <a href="#servicios">Servicios</a>
        <a href="#proceso">Proceso</a>
        <a href="#nosotros">Nosotros</a>
        <a href="#contacto">Contacto</a>
      </nav>

      <a href="https://www.instagram.com/skylink" target="_blank" rel="noopener noreferrer" class="footer-ig" aria-label="Instagram">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </div>

    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Bottom -->
    <div class="footer-bottom">
      <p>&copy; 2026 Skylink. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 2rem 1.5rem;
    background: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .footer-nav a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .footer-nav a:hover {
    color: var(--text-primary);
  }

  .footer-ig {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    text-decoration: none;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .footer-ig:hover {
    color: #E1306C;
    border-color: rgba(225, 48, 108, 0.35);
    background: rgba(225, 48, 108, 0.08);
  }

  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
    margin: 1.25rem 0;
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: var(--text-muted);
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .footer { padding: 1.5rem 1.25rem 1.25rem; }
    .footer-top {
      flex-direction: column;
      gap: 1rem;
    }
    .footer-nav {
      gap: 1.25rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
