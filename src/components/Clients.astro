---
const clients = [
  { src: '/logos/logos-clientes/logo-academia.jpg', alt: 'Academia' },
  { src: '/logos/logos-clientes/logo-alto-dominicos.jpg', alt: 'Alto Dominicos' },
  { src: '/logos/logos-clientes/logo-animalaria.webp', alt: 'Animalaria' },
  { src: '/logos/logos-clientes/logo-chile-adicto.svg', alt: 'Chile Adicto' },
  { src: '/logos/logos-clientes/logo-euclides.svg', alt: 'Euclides' },
  { src: '/logos/logos-clientes/logo-indrasolutions.webp', alt: 'Indra Solutions' },
  { src: '/logos/logos-clientes/logo-juste.png', alt: 'Juste' },
  { src: '/logos/logos-clientes/logo-klaims.svg', alt: 'Klaims' },
  { src: '/logos/logos-clientes/logo-MYH.png', alt: 'MYH' },
  { src: '/logos/logos-clientes/logo-navegue.png', alt: 'Navegue' },
  { src: '/logos/logos-clientes/logo-santiago-adicto.svg', alt: 'Santiago Adicto' },
  { src: '/logos/logos-clientes/logo-stickys.webp', alt: 'Stickys' },
  { src: '/logos/logos-clientes/logo-tcrm.png', alt: 'TCRM' },
  { src: '/logos/logos-clientes/logo-waw.webp', alt: 'WAW' },
];
---

<section class="clients" id="clientes">
  <div class="clients-container">
    <div class="clients-header reveal">
      <span class="section-tag">
        <span class="tag-pulse"></span>
        Clientes
      </span>
      <h2 class="clients-title">
        Empresas que <span class="text-gradient">confían</span> en nosotros
      </h2>
      <p class="clients-subtitle">
        Hemos tenido el privilegio de trabajar con marcas que nos desafían a dar lo mejor
      </p>
    </div>

    <div class="clients-marquee reveal reveal-delay-2">
      <div class="clients-track">
        {clients.map(client => (
          <div class="client-logo-wrap">
            <img src={client.src} alt={client.alt} class="client-logo" loading="lazy" />
          </div>
        ))}
        {clients.map(client => (
          <div class="client-logo-wrap">
            <img src={client.src} alt={client.alt} class="client-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <div class="clients-marquee clients-marquee-reverse reveal reveal-delay-3">
      <div class="clients-track clients-track-reverse">
        {[...clients].reverse().map(client => (
          <div class="client-logo-wrap">
            <img src={client.src} alt={client.alt} class="client-logo" loading="lazy" />
          </div>
        ))}
        {[...clients].reverse().map(client => (
          <div class="client-logo-wrap">
            <img src={client.src} alt={client.alt} class="client-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .clients {
    padding: 6rem 3rem 8rem;
    position: relative;
    overflow: hidden;
  }

  .clients::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(96, 176, 224, 0.2), transparent);
  }

  .clients-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .clients-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    background: rgba(96, 176, 224, 0.1);
    border: 1px solid rgba(96, 176, 224, 0.2);
    color: var(--accent-light);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .tag-pulse {
    width: 6px;
    height: 6px;
    background: #60c0f0;
    border-radius: 50%;
    animation: tagPulse 2s infinite;
    box-shadow: 0 0 8px rgba(96, 192, 240, 0.6);
  }

  @keyframes tagPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .clients-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .clients-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .clients-marquee {
    overflow: hidden;
    padding: 1.5rem 0;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .clients-marquee + .clients-marquee {
    margin-top: 0.5rem;
  }

  .clients-track {
    display: flex;
    gap: 3rem;
    align-items: center;
    animation: clientsScroll 50s linear infinite;
    width: max-content;
  }

  .clients-track-reverse {
    animation: clientsScrollReverse 55s linear infinite;
  }

  @keyframes clientsScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes clientsScrollReverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .client-logo-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 80px;
    padding: 1rem 1.5rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .client-logo-wrap:hover {
    border-color: rgba(96, 176, 224, 0.15);
    background: rgba(96, 176, 224, 0.05);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15), 0 0 30px rgba(96, 176, 224, 0.05);
  }

  .client-logo {
    max-width: 120px;
    max-height: 48px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) brightness(0.6) invert(0.9);
    opacity: 0.5;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .client-logo-wrap:hover .client-logo {
    filter: grayscale(0) brightness(1) invert(0);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .clients { padding: 4rem 1.5rem 5rem; }
    .client-logo-wrap {
      width: 130px;
      height: 65px;
      padding: 0.75rem 1rem;
    }
    .client-logo {
      max-width: 90px;
      max-height: 36px;
    }
  }
</style>
